# Required — Supabase (anon / publishable key only; never service)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_or_eyJ...

# Optional — Mapbox public access token (required for the /search map view).
# Get one free at https://account.mapbox.com/access-tokens/ — must start with "pk."
# When omitted, the map slot renders a friendly "Map disabled" fallback so the
# rest of /search still works.
NEXT_PUBLIC_MAPBOX_TOKEN=

# --- Batch geocoder (npm run geocode*) — Node 20+ loads this file via --env-file ---
# Same vars as Python loader — either name works:
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...   (or SUPABASE_SERVICE_KEY)
# GEOCODE_CONTACT_EMAIL=you@domain.com   (recommended for Nominatim)
